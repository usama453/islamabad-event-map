# AIRTABLE_TOKEN=patxxxxxxxxxxxxxxxx
# AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxx
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxxxx
# ADMIN_SECRET=pick-a-long-random-string

AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Shared live visitor count (required on Vercel; optional locally)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Password for the hidden /manage entries admin page
ADMIN_SECRET=

# Optional salt for daily IP hashes on submissions (falls back to ADMIN_SECRET)
# SUBMITTER_SALT=

# Airtable Entries fields to add (single-line text) for cleaner admin linking:
#   SubmitterId  — anonymous browser cookie id
#   IpHash       — daily-rotated IP hash (weak backup)
# Without these, signals are stored in Description and still work in /manage.
